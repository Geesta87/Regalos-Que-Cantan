{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/videos/:songId",
      "destination": "https://yzbvajungshqcpusfiia.supabase.co/storage/v1/object/public/videos/:songId"
    },
    { "source": "/share/:ids", "destination": "/api/share?ids=:ids" },
    { "source": "/(.*)", "destination": "/200.html" }
  ]
}
